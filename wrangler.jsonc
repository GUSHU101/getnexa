{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "getnexa",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "bcb0c533e59d0db8b4263c5d7347110f",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": { "enabled": true }
  },
  "workers_dev": true,
  "preview_urls": true,
  "placement": { "mode": "smart" },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/*.html", "/", "/index.html"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "getnexa-db",
      "database_id": "b7845773-0a43-46b5-9b1c-6b7b01e189ff"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "GAME_ROOM", "class_name": "GameRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["GameRoom"] }
  ],
  "routes": [
    { "pattern": "getnexa.space", "custom_domain": true },
    { "pattern": "www.getnexa.space", "custom_domain": true }
  ],
  "ai": {
    "binding": "AI"
  },
  "triggers": {
    "crons": ["0 * * * *", "0 */8 * * *"]
  }
}
