{
  "name": "getnexa",
  "version": "1.0.0",
  "description": "Nexa Arcade - play live HTML5 games, multiplayer, leaderboards, accounts. Hosted on Cloudflare Workers.",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-music.js && wrangler dev",
    "deploy": "node scripts/sync-music.js && wrangler deploy",
    "db:init": "wrangler d1 execute getnexa-db --file=./schema.sql --remote",
    "db:init-local": "wrangler d1 execute getnexa-db --file=./schema.sql --local",
    "db:migrate": "wrangler d1 execute getnexa-db --file=./migration-001.sql --remote --yes",
    "db:migrate-002": "wrangler d1 execute getnexa-db --file=./migration-002-hourly-featured.sql --remote --yes",
    "db:migrate-002-local": "wrangler d1 execute getnexa-db --file=./migration-002-hourly-featured.sql --local --yes",
    "predeploy": "npm run db:init || true",
    "tail": "wrangler tail",
    "sync-music": "node scripts/sync-music.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  }
}
